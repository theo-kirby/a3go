{
    "compileOnSave": false,
    "buildOnSave": false,
    "compilerOptions": {
        "target": "es2015",
        "module": "commonjs",
        "outDir": "./build/",
        "moduleResolution": "node",
        "removeComments": false,
        "declaration": true,
        "lib": ["es2015", "dom"],
        "baseUrl": ".",
        "paths": {
            "*": ["src/*", "*"],
            "engine": ["src/engine"]
        },

        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noImplicitOverride": true,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "noUnusedLocals": true,
        "allowJs": true,

        "sourceMap": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "test/**/*.ts"]
}
